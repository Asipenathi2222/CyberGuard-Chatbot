<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberGuard — Cybersecurity Awareness Bot"
        Height="780" Width="1000"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        FontFamily="Consolas">

	<Window.Resources>

		<!-- Palette -->
		<SolidColorBrush x:Key="BgDeep"      Color="#1A1A1A"/>
		<SolidColorBrush x:Key="BgPanel"     Color="#222222"/>
		<SolidColorBrush x:Key="BgCard"      Color="#2A2A2A"/>
		<SolidColorBrush x:Key="AccentLime"  Color="#AAFF00"/>
		<SolidColorBrush x:Key="AccentLimeDim" Color="#88CC00"/>
		<SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
		<SolidColorBrush x:Key="TextMuted"   Color="#888888"/>
		<SolidColorBrush x:Key="BorderGrey"  Color="#3A3A3A"/>

		<!-- Send Button -->
		<Style x:Key="SendButtonStyle" TargetType="Button">
			<Setter Property="Background"   Value="#AAFF00"/>
			<Setter Property="Foreground"   Value="#1A1A1A"/>
			<Setter Property="FontFamily"   Value="Consolas"/>
			<Setter Property="FontSize"     Value="14"/>
			<Setter Property="FontWeight"   Value="Bold"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"       Value="Hand"/>
			<Setter Property="Padding"      Value="20,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderThickness="1"
                                BorderBrush="#88CC00">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="#88CC00"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="border" Property="Background" Value="#66AA00"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Clear / Utility Button -->
		<Style x:Key="ClearButtonStyle" TargetType="Button">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="#888888"/>
			<Setter Property="FontFamily"      Value="Consolas"/>
			<Setter Property="FontSize"        Value="12"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush"     Value="#3A3A3A"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Padding"         Value="14,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background"   Value="#333333"/>
								<Setter TargetName="border" Property="BorderBrush"  Value="#666666"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Slim ScrollBar -->
		<Style TargetType="ScrollBar">
			<Setter Property="Background" Value="#222222"/>
			<Setter Property="Width"      Value="6"/>
		</Style>

	</Window.Resources>

	<!-- Root grid — overlays history panel on top when visible -->
	<Grid>

		<!-- ══════════════════════════════════════════════════════════ -->
		<!-- MAIN LAYOUT                                                -->
		<!-- ══════════════════════════════════════════════════════════ -->
		<Grid x:Name="MainLayout">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- ──────────────── HEADER ──────────────────────────── -->
			<Border Grid.Row="0"
                    Background="#222222"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1"
                    Padding="20,14">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- Logo -->
					<Border Grid.Column="0" Width="62" Height="62"
                            Background="#2A2A2A" CornerRadius="16"
                            BorderBrush="#AAFF00" BorderThickness="1.5"
                            Margin="0,0,18,0">
						<Grid>
							<Ellipse Width="34" Height="34" Fill="#223300" Opacity="0.6"/>
							<TextBlock Text="🛡" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#AAFF00"/>
						</Grid>
					</Border>

					<!-- Title -->
					<StackPanel Grid.Column="1" VerticalAlignment="Center">
						<TextBlock FontFamily="Consolas" FontWeight="Bold" FontSize="28">
							<Run Text="CYBER" Foreground="#FFFFFF"/>
							<Run Text="GUARD" Foreground="#AAFF00"/>
						</TextBlock>
						<TextBlock Text="Cybersecurity Awareness Assistant"
                                   Foreground="#BBBBBB" FontSize="12" Margin="2,4,0,0"/>
						<TextBlock Text="Secure • Educate • Protect"
                                   Foreground="#666666" FontSize="10" Margin="2,2,0,0"/>
					</StackPanel>

					<!-- Status indicators -->
					<StackPanel Grid.Column="2" VerticalAlignment="Center"
                                HorizontalAlignment="Right">
						<StackPanel Orientation="Horizontal" Margin="0,0,0,4">
							<Ellipse Width="8" Height="8" Fill="#AAFF00" Margin="0,0,6,0"/>
							<TextBlock Text="ONLINE" Foreground="#AAFF00" FontSize="10"/>
						</StackPanel>
						<StackPanel Orientation="Horizontal">
							<Ellipse Width="8" Height="8" Fill="#AAAAAA" Margin="0,0,6,0"/>
							<TextBlock x:Name="SessionLabel"
                                       Text="SESSION ACTIVE"
                                       Foreground="#888888" FontSize="10"/>
						</StackPanel>
					</StackPanel>

				</Grid>
			</Border>

			<!-- ──────────────── CHAT + SIDEBAR ──────────────────── -->
			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="220"/>
				</Grid.ColumnDefinitions>

				<!-- Chat area -->
				<Border Grid.Column="0" Background="#1A1A1A"
                        BorderBrush="#3A3A3A" BorderThickness="0,0,1,0">
					<ScrollViewer x:Name="ChatScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="16,12">
						<StackPanel x:Name="ChatPanel"
                                    Orientation="Vertical"
                                    Margin="0,0,8,0"/>
					</ScrollViewer>
				</Border>

				<!-- Sidebar -->
				<Border Grid.Column="1" Background="#222222" Padding="12,16">
					<ScrollViewer VerticalScrollBarVisibility="Auto">
						<StackPanel>

							<TextBlock Text="QUICK TOPICS"
                                       Foreground="#AAFF00" FontSize="11"
                                       FontWeight="Bold" Margin="0,0,0,12"/>

							<StackPanel x:Name="QuickTopicsPanel"/>

							<!-- Divider -->
							<TextBlock Text="────────────────"
                                       Foreground="#3A3A3A" FontSize="10"
                                       Margin="0,16,0,12"/>

							<!-- History toggle button -->
							<Button x:Name="HistoryButton"
                                    Content="📋 VIEW HISTORY"
                                    Margin="0,0,0,8"
                                    Padding="10,7,10,7"
                                    Background="#1E2D00"
                                    Foreground="#AAFF00"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    BorderBrush="#AAFF00"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    HorizontalContentAlignment="Center"
                                    Click="HistoryButton_Click">
								<Button.Template>
									<ControlTemplate TargetType="Button">
										<Border x:Name="hborder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
											<ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter TargetName="hborder"
                                                        Property="Background" Value="#2A3D00"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Button.Template>
							</Button>

							<!-- Divider -->
							<TextBlock Text="────────────────"
                                       Foreground="#3A3A3A" FontSize="10"
                                       Margin="0,4,0,12"/>

							<TextBlock Text="TIPS"
                                       Foreground="#AAFF00" FontSize="11"
                                       FontWeight="Bold" Margin="0,0,0,8"/>

							<TextBlock
                                Text="• Type 'tell me more'&#10;  to dig deeper&#10;&#10;• Ask 'what can you do'&#10;  for all topics&#10;&#10;• Share how you feel&#10;  for personalised help&#10;&#10;• Click 'VIEW HISTORY'&#10;  to see past questions"
                                Foreground="#888888" FontSize="10"
                                TextWrapping="Wrap" LineHeight="16"/>

						</StackPanel>
					</ScrollViewer>
				</Border>

			</Grid>

			<!-- ──────────────── STATUS BAR ───────────────────────── -->
			<Border Grid.Row="2"
                    Background="#1A1A1A"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,1,0,0"
                    Padding="20,6">
				<Grid>
					<TextBlock x:Name="StatusBar"
                               Text="Ready — Ask me anything about cybersecurity."
                               Foreground="#666666" FontSize="11"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
					<TextBlock x:Name="MessageCounter"
                               Text="0 messages"
                               Foreground="#555555" FontSize="11"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
				</Grid>
			</Border>

			<!-- ──────────────── INPUT AREA ───────────────────────── -->
			<Border Grid.Row="3"
                    Background="#222222"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,1,0,0"
                    Padding="16,14">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="90"/>
						<ColumnDefinition Width="8"/>
						<ColumnDefinition Width="80"/>
					</Grid.ColumnDefinitions>

					<!-- Input box -->
					<Border Grid.Column="0" Background="#2A2A2A"
                            CornerRadius="10" BorderBrush="#3A3A3A"
                            BorderThickness="1">
						<TextBox x:Name="UserInputBox"
                                 Background="Transparent"
                                 Foreground="#FFFFFF"
                                 CaretBrush="#AAFF00"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Padding="14,10"
                                 VerticalContentAlignment="Center"
                                 KeyDown="UserInput_KeyDown">
							<TextBox.Resources>
								<Style TargetType="{x:Type Border}">
									<Setter Property="CornerRadius" Value="10"/>
								</Style>
							</TextBox.Resources>
						</TextBox>
					</Border>

					<Button Grid.Column="2" x:Name="SendButton"
                            Content="SEND" Height="42"
                            Style="{StaticResource SendButtonStyle}"
                            Click="SendButton_Click"/>

					<Button Grid.Column="4" x:Name="ClearButton"
                            Content="CLEAR" Height="42"
                            Style="{StaticResource ClearButtonStyle}"
                            Click="ClearButton_Click"/>
				</Grid>
			</Border>

		</Grid>

		<!-- ══════════════════════════════════════════════════════════ -->
		<!-- HISTORY OVERLAY (shown on top when HistoryButton clicked)  -->
		<!-- ══════════════════════════════════════════════════════════ -->
		<Border x:Name="HistoryOverlay"
                Visibility="Collapsed"
                Background="#CC000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

			<!-- Centred card -->
			<Border Background="#222222"
                    BorderBrush="#AAFF00"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24,20"
                    Width="520"
                    MaxHeight="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Header -->
					<StackPanel Grid.Row="0" Orientation="Horizontal"
                                Margin="0,0,0,14">
						<TextBlock Text="📋 " FontSize="16"/>
						<TextBlock Text="CONVERSATION HISTORY"
                                   Foreground="#AAFF00"
                                   FontFamily="Consolas"
                                   FontSize="14" FontWeight="Bold"/>
					</StackPanel>

					<!-- Scrollable history list -->
					<ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="340">
						<StackPanel x:Name="HistoryList"/>
					</ScrollViewer>

					<!-- Close button -->
					<Button Grid.Row="2"
                            Content="CLOSE"
                            Margin="0,16,0,0"
                            Height="36"
                            Style="{StaticResource ClearButtonStyle}"
                            HorizontalAlignment="Right"
                            Padding="24,0"
                            Click="HistoryButton_Click"/>

				</Grid>
			</Border>
		</Border>

	</Grid>

</Window>
